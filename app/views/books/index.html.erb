<h1>Books</h1>

<table>
      <thead>
            <tr>
               <th>Title</th>
               <th>Body</th>
               <th></th> </tr>
      </thead>

  <tbody>
      <% @books.each do |book| %>                  
         <tr>
            <td><%= book.title %></td>
            <td><%= book.body %></td>
            <td>
               <span><%= link_to 'show', book_path(book.id) %></span>
               <span><%= link_to 'edit', edit_book_path(book.id)%></span>
               <span><%= link_to 'Destroy', book_path(book.id), data: { turbo_method: :delete, turbo_confirm: 'Are you sure?' } %></span> 
            </td>
         </tr>
        <% end %>

  





  </tbody>

</table>

 




